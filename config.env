# Link do código fonte oficial do Google para Kernels modernos (GKI)
KERNEL_SOURCE=https://android.googlesource.com/kernel/common
KERNEL_SOURCE_BRANCH=android15-6.6
KERNEL_CONFIG=gki_defconfig
KERNEL_IMAGE_NAME=Image
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=true

# Ativação do KernelSU Next e do SUSFS
KSU=true
KSU_NEXT=true
SUSFS=true
SUSFS_VERSION=v2.1.0

# Aqui é onde a gente coloca o nome "Samsung" para enganar o sistema (Spoof)
EXTRA_CMDS="CONFIG_LOCALVERSION=-Samsung-S24U"

# Configuração do compilador (Clang) para Android 15 / Kernel 6.6
# Ativa o compilador customizado (mais estável)
USE_CUSTOM_CLANG=true
CUSTOM_CLANG_SOURCE=https://github.com/ZyCromerZ/Clang
CUSTOM_CLANG_BRANCH=19
CUSTOM_CMDS="CLANG_TRIPLE=aarch64-linux-gnu-"
