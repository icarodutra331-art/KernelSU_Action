CONFIG_ENV=config.env

KERNEL_SOURCE=https://android.googlesource.com/kernel/common
KERNEL_SOURCE_BRANCH=android15-6.6
KERNEL_CONFIG=gki_defconfig
KERNEL_IMAGE_NAME=Image
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=true

# Simplificando o nome para evitar erro de leitura
EXTRA_CMDS="CONFIG_LOCALVERSION=-S24U"

# Compilador que a gente já sabe que baixa certo
USE_CUSTOM_CLANG=true
CUSTOM_CLANG_SOURCE=https://github.com/ZyCromerZ/Clang
CUSTOM_CLANG_BRANCH=main

# Vamos usar o KernelSU padrão (oficial) para garantir que compile
ENABLE_KERNELSU=true
KSU_NEXT=false
SUSFS=false
